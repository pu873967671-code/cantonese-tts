{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@canto/shared/*": ["packages/shared/src/*"],
      "@canto/preprocess/*": ["packages/preprocess/src/*"],
      "@canto/lexicon/*": ["packages/lexicon/src/*"],
      "@canto/tts-core/*": ["packages/tts-core/src/*"],
      "@canto/db/*": ["packages/db/src/*"]
    }
  }
}
