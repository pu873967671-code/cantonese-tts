{
  "name": "cantonese-tts",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "concurrently -n api,worker,web -c blue,magenta,green \"pnpm --filter api dev\" \"pnpm --filter worker dev\" \"pnpm --filter web dev\"",
    "dev:api": "pnpm --filter api dev",
    "dev:worker": "pnpm --filter worker dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @canto/db prisma generate",
    "db:migrate": "pnpm --filter @canto/db prisma migrate dev",
    "db:studio": "pnpm --filter @canto/db prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.8.2"
  }
}
